# ── Protiviti Operational Audit Assistant — Environment Variables ──────────
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── LLM Provider ──────────────────────────────────────────────────────────
# Leave AZURE_ENDPOINT blank to use standard OpenAI (default for sandbox testing).
# Set AZURE_ENDPOINT to use Azure OpenAI (recommended for local/corporate use).

AZURE_ENDPOINT=
# Example: https://my-resource.openai.azure.com/

AZURE_OPENAI_DEPLOYMENT=gpt-4o
# The deployment name in your Azure OpenAI resource.

API_KEY=
# Azure: your Azure OpenAI API key.
# Standard OpenAI: leave blank and set OPENAI_API_KEY below.

API_VERSION=2024-02-01
# Azure API version. Leave as-is unless you need a specific version.

IS_O_SERIES=false
# Set to true if using an o-series model (o1, o3, etc.) which requires different parameters.

SUBSCRIPTION_KEY=
# Optional: corporate API gateway header name.
# If set, this header name is sent with API_KEY as the value.
# Example: Ocp-Apim-Subscription-Key

# ── Standard OpenAI (used when AZURE_ENDPOINT is blank) ───────────────────
OPENAI_API_KEY=
# Your OpenAI API key from https://platform.openai.com/api-keys

OPENAI_MODEL=gpt-4.1-mini
# Model to use when running in sandbox mode (non-Azure).

# ── App Settings ──────────────────────────────────────────────────────────
PORT=8000
# Port the app listens on. Open http://localhost:8000 in your browser.
